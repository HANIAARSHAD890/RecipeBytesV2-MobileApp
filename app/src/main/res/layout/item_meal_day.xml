<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Purple top strip -->
        <View
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:background="@color/secondary"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <!-- Date badge -->
                <LinearLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/date_badge_bg">

                    <TextView
                        android:id="@+id/tvDayNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/buttontext" />

                    <TextView
                        android:id="@+id/tvDayAbbr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mon"
                        android:textSize="10sp"
                        android:textColor="@color/buttontext" />

                </LinearLayout>

                <!-- Day name + meal count -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvDayName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monday, May 1"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/textcolor" />

                    <TextView
                        android:id="@+id/tvMealCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No meals planned"
                        android:textSize="12sp"
                        android:textColor="@color/secondary" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddMeal"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="+ Add"
                    android:textSize="12sp"
                    android:textColor="@color/secondary"
                    app:strokeColor="@color/secondary"
                    app:cornerRadius="18dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />

            </LinearLayout>

            <!-- Empty state -->
            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🍽  Tap + Add to plan your meals"
                android:textSize="13sp"
                android:textColor="@color/secondary"
                android:gravity="center"
                android:alpha="0.7"
                android:paddingBottom="4dp"/>

            <!-- Breakfast -->
            <LinearLayout
                android:id="@+id/rowBreakfast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌅  Breakfast"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipBreakfast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>

            <!-- Lunch -->
            <LinearLayout
                android:id="@+id/rowLunch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☀️  Lunch"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipLunch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>

            <!-- Dinner -->
            <LinearLayout
                android:id="@+id/rowDinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙  Dinner"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipDinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>

            <!-- Dessert -->
            <LinearLayout
                android:id="@+id/rowDessert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🍰  Dessert"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipDessert"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>