<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:padding="12dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Top Row: Profile + Username + Toggle + Delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop"
                android:contentDescription="User profile picture"
                android:background="@drawable/circle_bg"
                android:visibility="gone" />

            <TextView
                android:id="@+id/profileCircle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:background="@drawable/circle_bg"
                />

            <TextView
                android:id="@+id/textUsername"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textSize="14sp"
                android:textColor="@color/textcolor"
                android:text="Loading..." />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/textPublicPrivate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Public"
                    android:textColor="@color/gray"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="6dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchPublic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/switch_thumb"
                    app:trackTint="@color/switch_track"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Recipe Image with Heart Overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="150dp">

            <ImageView
                android:background="@color/bgcolor"
                android:id="@+id/imageRecipe"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/camera_upload_icon"/>

            <TextView
                android:id="@+id/iconFavorite"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:gravity="center"
                android:textSize="22sp"
                android:text="♡"
                android:background="@drawable/circle_bg"
                android:alpha="0.85" />
        </FrameLayout>

        <TextView
            android:id="@+id/textTitle"
            android:textStyle="bold"
            android:textSize="15sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="@color/textcolor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingMultiplier="0.9"/>

        <TextView
            android:id="@+id/textDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="13sp"
            android:lineSpacingMultiplier="0.9"
            android:textColor="@color/textcolor"/>

        <!-- Likers count -->
        <TextView
            android:id="@+id/textLikersCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:textSize="12sp"
            android:textColor="@color/gray"
            android:text="0 likes"
            android:clickable="true"
            android:focusable="true" />

        <!-- Like and Share row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/iconLike"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_thumb_up"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/textLikesCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:text="0" />

            <ImageView
                android:id="@+id/iconShare"
                android:layout_width="24dp"
                android:layout_height="24dp"
                app:tint="@color/gray"
                android:layout_marginStart="12dp"
                android:src="@android:drawable/ic_menu_share"
                android:clickable="true"
                android:focusable="true" />

            <ImageView
                android:id="@+id/iconCopy"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_copy"
                app:tint="@color/gray"
                android:clickable="true"
                android:focusable="true"
                android:scaleType="fitCenter" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/iconDelete"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/red"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/textCreatedAt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:visibility="gone"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
