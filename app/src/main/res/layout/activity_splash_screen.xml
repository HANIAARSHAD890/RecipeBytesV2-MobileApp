<?xml version="1.0" encoding="utf-8"?>
<!-- Layout for the Splash screen, shown when the app is first launched. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/appBackground"
    tools:context=".activities.SplashScreen">

    <!-- App welcome title -->
    <TextView
        android:id="@+id/tvTitle"
        android:fontFamily="@font/poppins_semibold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to Recipe Bytes"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/textcolor"
        android:gravity="center" />

    <!-- App logo -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/logo_app"
        android:contentDescription="App Logo"
        android:layout_marginTop="40dp"/>

    <!-- App tagline -->
    <TextView
        android:id="@+id/tvSmallText"
        android:fontFamily="@font/poppins_semibold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your smart cooking companion"
        android:textSize="16sp"
        android:textColor="@color/primary"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"/>

    <!-- Entry button to start using the app -->
    <Button
        android:id="@+id/btnExplore"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Let's Explore"
        android:textAllCaps="false"
        android:backgroundTint="@color/secondary"
        android:textColor="@color/buttontext"/>

</LinearLayout>