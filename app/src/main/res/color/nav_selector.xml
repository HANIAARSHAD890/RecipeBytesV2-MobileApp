<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- When the icon is selected, show WHITE (or your nav_item_color) -->
    <item android:color="@color/nav_item_color" android:state_checked="true" />

    <!-- When the icon is NOT selected, show a faded white or grey -->
    <item android:color="#B3FFFFFF" android:state_checked="false" />
</selector>