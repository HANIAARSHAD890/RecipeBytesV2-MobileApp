<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Light background -->
    <solid android:color="@color/bgcolor"/>

    <!-- Rounded corners -->
    <corners android:radius="16dp"/>

    <!-- Border -->
    <stroke
        android:width="1dp"
        android:color="@color/bgcolor"/>

    <!-- Padding -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="10dp"
        android:bottom="10dp"/>
</shape>